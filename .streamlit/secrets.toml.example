# Copy to ".streamlit/secrets.toml" to set defaults via Streamlit secrets.
# (Same keys as .env — secrets take precedence over environment variables.)
# This file (the .example) is safe to commit; secrets.toml itself is gitignored.

# DB_URL = "postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME"
# DB_TABLE = "countries"

# AI_PROVIDER = "offline"   # offline | ollama | openai
# AI_MODEL = "qwen2.5"
# AI_BASE_URL = "https://api.deepseek.com/v1"
# AI_API_KEY = "sk-..."
