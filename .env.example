# Copy to ".env" and fill in, OR enter everything live in the app sidebar.
# These are only DEFAULTS — the app never hardcodes credentials.

# ---- Database (optional) -----------------------------------------------------
# SQLAlchemy connection string used as the default in the "Connect database" source.
#   PostgreSQL: postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
#   MySQL:      mysql+pymysql://USER:PASSWORD@HOST:3306/DBNAME
#   SQLite:     sqlite:///path/to/file.db
DB_URL=
DB_TABLE=countries

# ---- AI provider (optional) --------------------------------------------------
# AI_PROVIDER: offline | ollama | openai   (offline needs no keys and powers the demo)
AI_PROVIDER=offline
AI_MODEL=qwen2.5
# Only for OpenAI-compatible APIs (OpenAI, DeepSeek, Together, Groq, ...):
AI_BASE_URL=
AI_API_KEY=
